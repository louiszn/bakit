{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!!**/node_modules",
			"!!**/dist",
			"!!**/build",
			"!!**/coverage",
			"!!**/.turbo",
			"!!**/.svelte-kit",
			"!!**/.vite"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"style": {
				"noCommonJs": "error",
				"noDefaultExport": "error",
				"noEnum": "error",
				"noExportedImports": "error",
				"noParameterProperties": "error",
				"useConsistentMemberAccessibility": {
					"level": "error",
					"options": {
						"accessibility": "noPublic"
					}
				},
				"useExportType": "error",
				"useImportType": "error",
				"useNodejsImportProtocol": "error"
			},
			"suspicious": {
				"noConstEnum": "error",
				"noExplicitAny": "warn",
				"noFocusedTests": "error",
				"noImplicitAnyLet": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"trailingCommas": "none"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
